# ============================================================
# PrimeEstate India — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ============================================================

# App meta
VITE_APP_NAME="PrimeEstate India"
VITE_APP_URL="https://primeestate.in"

# --- Add your own services below ---

# Google Maps (for property location maps)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Supabase (for auth + database — free tier available)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudinary (for property photo uploads)
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Email (for contact form — e.g. EmailJS)
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID=your_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key

# WhatsApp Business Number (for direct chat CTAs)
# VITE_WHATSAPP_NUMBER=919876543210
